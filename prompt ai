import React, { useState, useEffect } from 'react';
import { initializeApp } from 'firebase/app';
import { 
  getFirestore, 
  collection, 
  addDoc, 
  onSnapshot, 
  query, 
  limit 
} from 'firebase/firestore';
import { 
  getAuth, 
  signInAnonymously, 
  signInWithCustomToken, 
  onAuthStateChanged 
} from 'firebase/auth';
import { 
  Copy, 
  Sparkles, 
  CheckCircle,
  MapPin,
  Users,
  MessageSquare,
  Film,
  Info,
  Globe,
  Share2,
  AlertTriangle,
  ChevronRight,
  History,
  Loader2,
  ExternalLink
} from 'lucide-react';

// Inisialisasi Firebase yang aman
let app, auth, db;
try {
  const firebaseConfig = JSON.parse(__firebase_config);
  app = initializeApp(firebaseConfig);
  auth = getAuth(app);
  db = getFirestore(app);
} catch (e) {
  console.error("Firebase Init Error:", e);
}

const appId = typeof __app_id !== 'undefined' ? __app_id : 'bikini-bottom-studio-v2';
const API_KEY = ""; 

const App = () => {
  const [user, setUser] = useState(null);
  const [authStatus, setAuthStatus] = useState('connecting');
  const [inputStory, setInputStory] = useState('');
  const [inputDialogue, setInputDialogue] = useState('');
  const [optimizedPrompt, setOptimizedPrompt] = useState('');
  const [isOptimizing, setIsOptimizing] = useState(false);
  const [notification, setNotification] = useState(null);
  const [publicPrompts, setPublicPrompts] = useState([]);
  const [showShareModal, setShowShareModal] = useState(false);
  
  const [selectedLocation, setSelectedLocation] = useState('Restoran');
  const [selectedCitizen, setSelectedCitizen] = useState('Fred');

  const locations = [
    { name: 'Restoran', icon: '🍔' },
    { name: 'Rumah', icon: '🏠' },
    { name: 'Pantai', icon: '🏖️' },
    { name: 'Kota', icon: '🏢' },
    { name: 'Taman', icon: '🧤' }
  ];

  const iconicCitizens = [
    { id: 'Fred', name: 'Fred', icon: '🦵', desc: 'The brown fish citizen famous for shouting "My Leg!"' },
    { id: 'Tom', name: 'Tom', icon: '🍫', desc: 'The green fish citizen obsessed with chocolate.' },
    { id: 'Nat', name: 'Nat', icon: '🐟', desc: 'The yellow fish citizen, background driver.' },
    { id: 'Harold', name: 'Harold', icon: '👕', desc: 'The blue fish with a white shirt.' },
    { id: 'Scooter', name: 'Scooter', icon: '🏄', desc: 'The purple surfer fish.' },
    { id: 'Jenkins', name: 'Old Man Jenkins', icon: '👴', desc: 'The elderly thin fish.' }
  ];

  useEffect(() => {
    const initAuth = async () => {
      try {
        if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
          await signInWithCustomToken(auth, __initial_auth_token);
        } else {
          await signInAnonymously(auth);
        }
      } catch (err) {
        console.error("Auth Error:", err);
        setAuthStatus('error');
      }
    };
    
    if (auth) {
      initAuth();
      const unsubscribe = onAuthStateChanged(auth, (u) => {
        if (u) {
          setUser(u);
          setAuthStatus('authenticated');
        }
      });
      return () => unsubscribe();
    } else {
      setAuthStatus('error');
    }
  }, []);

  useEffect(() => {
    if (!user || !db) return;
    
    const promptsCol = collection(db, 'artifacts', appId, 'public', 'data', 'prompts');
    const unsubscribe = onSnapshot(promptsCol, (snapshot) => {
      const data = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
      setPublicPrompts(data.sort((a, b) => (b.timestamp || 0) - (a.timestamp || 0)).slice(0, 25));
    }, (error) => {
      console.error("Firestore Error:", error);
    });

    return () => unsubscribe();
  }, [user]);

  const showNotification = (msg) => {
    setNotification(msg);
    setTimeout(() => setNotification(null), 3000);
  };

  const copyToClipboard = (text) => {
    const targetText = text || optimizedPrompt;
    if (!targetText) return;
    const textArea = document.createElement("textarea");
    textArea.value = targetText;
    document.body.appendChild(textArea);
    textArea.select();
    document.execCommand('copy');
    document.body.removeChild(textArea);
    showNotification("Berhasil disalin!");
  };

  const optimizePrompt = async () => {
    if (!inputStory && !inputDialogue) return;
    setIsOptimizing(true);
    
    const citizenData = iconicCitizens.find(c => c.id === selectedCitizen);
    const systemPrompt = `You are a professional Sora Video Prompt Engineer. 15-sec 2D animation. Style: Bikini Bottom TV show. Main char: ${citizenData.desc}. Plot: ${inputStory}. Dialogue: ${inputDialogue} (Indonesian). Result only.`;
    
    let retries = 0;
    const callApi = async () => {
      try {
        const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${API_KEY}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            contents: [{ parts: [{ text: `Location ${selectedLocation}. Story: ${inputStory}. Dialogue: ${inputDialogue}.` }] }],
            systemInstruction: { parts: [{ text: systemPrompt }] }
          })
        });
        
        const data = await response.json();
        const text = data.candidates?.[0]?.content?.parts?.[0]?.text;
        if (text) {
          const finalPrompt = text.trim();
          setOptimizedPrompt(finalPrompt);
          saveToPublic(finalPrompt);
          showNotification("Prompt terbit di feed global!");
        }
      } catch (err) {
        if (retries < 5) {
          retries++;
          setTimeout(callApi, Math.pow(2, retries) * 1000);
        } else {
          showNotification("Gagal memproses AI.");
        }
      } finally {
        setIsOptimizing(false);
      }
    };
    callApi();
  };

  const saveToPublic = async (promptText) => {
    if (!user || !db) return;
    try {
      const promptsCol = collection(db, 'artifacts', appId, 'public', 'data', 'prompts');
      await addDoc(promptsCol, {
        citizen: selectedCitizen,
        location: selectedLocation,
        prompt: promptText,
        timestamp: Date.now(),
        userName: `Warga-${user.uid.substring(0,4)}`
      });
    } catch (e) {
      console.error("Error saving:", e);
    }
  };

  if (authStatus === 'connecting') {
    return (
      <div className="h-screen w-screen bg-slate-950 flex flex-col items-center justify-center text-white text-center">
        <Loader2 className="w-12 h-12 text-blue-500 animate-spin mb-6" />
        <h2 className="text-2xl font-black uppercase italic tracking-tighter">Memuat Studio Global...</h2>
        <p className="text-slate-500 text-sm mt-2 animate-pulse">Menghubungkan ke database Bikini Bottom</p>
      </div>
    );
  }

  return (
    <div className="h-screen w-screen bg-slate-950 text-white font-sans flex flex-col overflow-hidden selection:bg-blue-500 selection:text-white">
      
      {/* Header Utama - Full Width */}
      <header className="h-16 border-b border-slate-800 bg-slate-900/80 backdrop-blur-xl flex items-center justify-between px-6 shrink-0 z-50 shadow-lg">
        <div className="flex items-center gap-4">
          <div className="w-10 h-10 bg-yellow-400 rounded-xl flex items-center justify-center rotate-3 shadow-[0_0_20px_rgba(250,204,21,0.3)] group cursor-pointer">
            <Globe size={22} className="text-slate-950 group-hover:rotate-12 transition-transform" />
          </div>
          <div className="hidden sm:block">
            <h1 className="text-lg font-black tracking-tighter text-white uppercase italic leading-none">
              BIKINI BOTTOM <span className="text-blue-500">STUDIO</span>
            </h1>
            <p className="text-[9px] text-slate-500 font-bold uppercase tracking-[0.2em] mt-1 italic">Professional Feed System</p>
          </div>
        </div>

        <div className="flex items-center gap-4">
          <div className="hidden lg:flex flex-col items-end border-r border-slate-800 pr-4">
            <div className="flex items-center gap-2">
              <span className="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></span>
              <span className="text-[9px] font-black text-green-500 uppercase">Server Active</span>
            </div>
            <span className="text-[8px] text-slate-500 font-bold uppercase">ID: {user?.uid.substring(0,12)}</span>
          </div>
          
          <button 
            onClick={() => setShowShareModal(true)}
            className="bg-slate-800 hover:bg-slate-700 text-white px-4 py-2.5 rounded-xl text-[10px] font-black flex items-center gap-2 transition-all border border-slate-700 active:scale-95"
          >
            <Share2 size={14}/> BAGIKAN LINK
          </button>
        </div>
      </header>

      {/* Main Container - Full Screen Split */}
      <main className="flex flex-1 overflow-hidden">
        
        {/* Kolom Kiri: Editor (40% Width) */}
        <section className="w-full lg:w-[460px] border-r border-slate-800 bg-slate-900/30 flex flex-col overflow-y-auto scrollbar-hide shrink-0">
          <div className="p-8 space-y-10 pb-24">
            
            {/* Pemilihan Karakter */}
            <div className="space-y-4">
              <div className="flex items-center justify-between">
                <h2 className="text-[11px] font-black text-slate-500 uppercase tracking-[0.2em] flex items-center gap-2">
                  <Users size={14} className="text-yellow-500" /> 01. Karakter Warga
                </h2>
              </div>
              <div className="grid grid-cols-3 gap-2">
                {iconicCitizens.map(citizen => (
                  <button 
                    key={citizen.id} 
                    onClick={() => setSelectedCitizen(citizen.id)}
                    className={`flex flex-col items-center p-3 rounded-2xl border-2 transition-all group ${selectedCitizen === citizen.id ? 'bg-yellow-500/10 border-yellow-500 shadow-[0_0_15px_rgba(234,179,8,0.1)] scale-105' : 'bg-slate-800/40 border-transparent hover:bg-slate-800'}`}
                  >
                    <span className="text-3xl mb-1 group-hover:scale-110 transition-transform">{citizen.icon}</span>
                    <span className="text-[10px] font-black uppercase text-center truncate w-full">{citizen.name}</span>
                  </button>
                ))}
              </div>
            </div>

            {/* Pemilihan Lokasi */}
            <div className="space-y-4">
              <h2 className="text-[11px] font-black text-slate-500 uppercase tracking-[0.2em] flex items-center gap-2">
                <MapPin size={14} className="text-blue-500" /> 02. Setting Lokasi
              </h2>
              <div className="grid grid-cols-2 gap-2">
                {locations.map(loc => (
                  <button 
                    key={loc.name} 
                    onClick={() => setSelectedLocation(loc.name)}
                    className={`px-4 py-3.5 rounded-2xl text-[10px] font-black uppercase transition-all border-2 flex items-center gap-3 ${selectedLocation === loc.name ? 'bg-blue-600 border-blue-400 text-white shadow-xl shadow-blue-600/20' : 'bg-slate-800/40 border-transparent text-slate-400 hover:bg-slate-800'}`}
                  >
                    <span className="text-lg">{loc.icon}</span> {loc.name}
                  </button>
                ))}
              </div>
            </div>

            {/* Editor Skenario */}
            <div className="space-y-6">
              <h2 className="text-[11px] font-black text-slate-500 uppercase tracking-[0.2em] flex items-center gap-2">
                <Film size={14} className="text-indigo-500" /> 03. Detail Adegan
              </h2>
              <div className="space-y-4">
                <div className="space-y-2">
                  <label className="text-[10px] font-black text-slate-600 uppercase ml-1">Alur Cerita / Plot</label>
                  <textarea 
                    placeholder="Contoh: Dia sedang santai makan cokelat tapi tiba-tiba ada hiu datang..."
                    value={inputStory}
                    onChange={(e) => setInputStory(e.target.value)}
                    className="w-full bg-slate-950/50 border border-slate-800 rounded-2xl p-5 text-sm h-36 focus:ring-2 focus:ring-yellow-500/20 focus:border-yellow-500 outline-none transition-all resize-none shadow-inner"
                  />
                </div>
                <div className="space-y-2">
                  <label className="text-[10px] font-black text-slate-600 uppercase ml-1">Dialog Karakter</label>
                  <textarea 
                    placeholder="Apa yang mereka bicarakan?..."
                    value={inputDialogue}
                    onChange={(e) => setInputDialogue(e.target.value)}
                    className="w-full bg-slate-950/50 border border-slate-800 rounded-2xl p-5 text-sm h-36 focus:ring-2 focus:ring-green-500/20 focus:border-green-500 outline-none transition-all resize-none shadow-inner"
                  />
                </div>
              </div>
            </div>

            {/* Tombol Aksi */}
            <button 
              onClick={optimizePrompt}
              disabled={isOptimizing || (!inputStory && !inputDialogue)}
              className={`w-full py-6 rounded-2xl font-black uppercase italic transition-all flex items-center justify-center gap-4 text-xl tracking-tighter relative overflow-hidden group ${isOptimizing ? 'bg-slate-800 cursor-not-allowed' : 'bg-white text-slate-950 hover:bg-yellow-400 active:scale-[0.98] shadow-[0_20px_40px_rgba(0,0,0,0.3)] hover:shadow-yellow-500/20'}`}
            >
              {isOptimizing ? (
                <Loader2 className="animate-spin text-slate-400" size={24} />
              ) : (
                <>
                  <Sparkles size={24} className="text-blue-600 group-hover:rotate-12 transition-transform" /> 
                  PUBLIKASIKAN KE FEED
                </>
              )}
            </button>
          </div>
        </section>

        {/* Kolom Kanan: Live Global Feed (60% Width) */}
        <section className="flex-1 bg-slate-950 flex flex-col min-w-0 relative">
          
          {/* Sub-Header Feed */}
          <div className="h-14 px-8 border-b border-slate-900 flex items-center justify-between bg-slate-950/50 backdrop-blur-sm sticky top-0 z-10 shrink-0">
            <div className="flex items-center gap-3">
              <History size={16} className="text-blue-500" />
              <h2 className="text-[11px] font-black uppercase tracking-[0.3em] text-slate-500 italic">Live Global Broadcast</h2>
            </div>
            <div className="flex items-center gap-2 bg-green-500/10 border border-green-500/20 px-3 py-1 rounded-full">
              <span className="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></span>
              <span className="text-[9px] font-black text-green-500 uppercase tracking-widest">Live Updates</span>
            </div>
          </div>

          {/* Grid Feed yang Luas */}
          <div className="flex-1 overflow-y-auto p-8 lg:p-12 scrollbar-hide">
            <div className="grid grid-cols-1 md:grid-cols-2 2xl:grid-cols-3 gap-6 auto-rows-max max-w-[1400px] mx-auto">
              {publicPrompts.length > 0 ? (
                publicPrompts.map((p) => (
                  <div key={p.id} className="bg-slate-900/30 border border-slate-800/50 rounded-[2.5rem] p-8 flex flex-col gap-5 hover:border-blue-500/40 transition-all group relative hover:-translate-y-2 shadow-2xl overflow-hidden">
                    <div className="flex justify-between items-start">
                      <div className="space-y-1.5">
                        <div className="flex items-center gap-2">
                          <span className="inline-flex px-2 py-0.5 bg-yellow-500 text-slate-950 text-[9px] font-black uppercase italic rounded-md">
                            {p.citizen}
                          </span>
                          <span className="text-[9px] font-black text-blue-500 uppercase tracking-widest opacity-60">
                            @ {p.location}
                          </span>
                        </div>
                        <div className="text-[8px] text-slate-600 font-bold uppercase tracking-[0.1em]">{p.userName} • {new Date(p.timestamp).toLocaleTimeString()}</div>
                      </div>
                      <button 
                        onClick={() => copyToClipboard(p.prompt)} 
                        className="bg-slate-800/80 p-2.5 rounded-xl text-slate-400 hover:text-white hover:bg-blue-600 transition-all opacity-0 group-hover:opacity-100 shadow-lg border border-slate-700"
                      >
                        <Copy size={14}/>
                      </button>
                    </div>
                    
                    <div className="relative">
                      <p className="text-[13px] text-slate-300 italic leading-relaxed font-medium line-clamp-5 group-hover:line-clamp-none transition-all">
                        "{p.prompt}"
                      </p>
                    </div>

                    <div className="mt-auto pt-5 border-t border-slate-800/40 flex items-center justify-between">
                       <div className="flex gap-1">
                          <div className="w-1.5 h-1.5 rounded-full bg-slate-800"></div>
                          <div className="w-1.5 h-1.5 rounded-full bg-slate-800"></div>
                          <div className="w-1.5 h-1.5 rounded-full bg-slate-800"></div>
                       </div>
                       <ChevronRight size={14} className="text-slate-800 group-hover:text-blue-500 group-hover:translate-x-1 transition-all" />
                    </div>

                    {/* Efek Cahaya Belakang */}
                    <div className="absolute -top-10 -right-10 w-32 h-32 bg-blue-600/5 blur-[50px] rounded-full pointer-events-none group-hover:bg-blue-600/10 transition-colors"></div>
                  </div>
                ))
              ) : (
                <div className="col-span-full h-[60vh] flex flex-col items-center justify-center opacity-30 text-center space-y-4">
                  <div className="w-24 h-24 border-2 border-slate-800 border-dashed rounded-full flex items-center justify-center animate-spin-slow">
                    <Globe size={48} />
                  </div>
                  <p className="text-base font-black uppercase tracking-[0.4em] animate-pulse">Menghubungkan Database...</p>
                </div>
              )}
            </div>
          </div>

          {/* Hasil Prompt User (Popup) */}
          {optimizedPrompt && (
            <div className="absolute bottom-10 right-10 left-10 md:left-auto md:w-[450px] animate-in slide-in-from-right-10 duration-500 z-30">
               <div className="bg-white text-slate-950 p-8 rounded-[3rem] shadow-[0_30px_60px_rgba(0,0,0,0.5)] border-4 border-blue-600 relative overflow-hidden">
                  <div className="absolute top-0 right-0 p-4">
                     <button onClick={() => setOptimizedPrompt('')} className="w-8 h-8 flex items-center justify-center rounded-full hover:bg-slate-100 transition-colors">✕</button>
                  </div>
                  <div className="flex items-center gap-3 mb-6">
                    <div className="p-2 bg-blue-600 rounded-lg text-white">
                      <Sparkles size={18} />
                    </div>
                    <h3 className="text-xs font-black uppercase tracking-widest text-blue-600">Generated Prompt</h3>
                  </div>
                  <div className="bg-slate-50 border border-slate-200 rounded-2xl p-6 mb-8">
                    <p className="text-sm font-bold leading-relaxed italic text-slate-800">"{optimizedPrompt}"</p>
                  </div>
                  <button 
                    onClick={() => copyToClipboard()}
                    className="w-full py-4 bg-blue-600 hover:bg-blue-700 text-white rounded-2xl font-black text-sm uppercase transition-all shadow-xl flex items-center justify-center gap-3 active:scale-95"
                  >
                    <Copy size={16}/> SALIN PROMPT SAYA
                  </button>
               </div>
            </div>
          )}
        </section>

      </main>

      {/* Share Modal */}
      {showShareModal && (
        <div className="fixed inset-0 z-[100] flex items-center justify-center p-6 bg-slate-950/80 backdrop-blur-md animate-in fade-in">
          <div className="bg-slate-900 border border-slate-800 p-8 rounded-[2.5rem] max-w-md w-full shadow-2xl space-y-6">
            <div className="text-center space-y-2">
              <h2 className="text-2xl font-black italic uppercase tracking-tighter">Bagi Hasil Karya!</h2>
              <p className="text-slate-500 text-xs font-medium leading-relaxed uppercase tracking-widest">Klik tombol di bawah untuk menyalin link pratinjau</p>
            </div>
            
            <div className="space-y-4">
               <button 
                onClick={() => {
                  const url = window.location.href;
                  const textArea = document.createElement("textarea");
                  textArea.value = url;
                  document.body.appendChild(textArea);
                  textArea.select();
                  document.execCommand('copy');
                  document.body.removeChild(textArea);
                  showNotification("Link disalin!");
                  setShowShareModal(false);
                }}
                className="w-full py-5 bg-blue-600 hover:bg-blue-500 text-white rounded-2xl font-black uppercase tracking-tighter flex items-center justify-center gap-3 transition-all"
               >
                 <Copy size={20} /> SALIN LINK SEKARANG
               </button>
               
               <div className="flex items-start gap-4 p-4 bg-yellow-500/10 rounded-2xl border border-yellow-500/20">
                  <Info className="text-yellow-500 shrink-0 mt-0.5" size={18} />
                  <p className="text-[10px] text-yellow-500/80 font-bold uppercase leading-relaxed tracking-wider">
                    Pastikan teman Anda membuka link ini di browser agar bisa melihat database feed secara langsung (Real-time).
                  </p>
               </div>
            </div>

            <button 
              onClick={() => setShowShareModal(false)}
              className="w-full text-[10px] font-black uppercase text-slate-500 tracking-widest hover:text-white transition-colors"
            >
              Kembali ke Studio
            </button>
          </div>
        </div>
      )}

      {/* Notification Toast */}
      {notification && (
        <div className="fixed bottom-10 left-1/2 -translate-x-1/2 bg-yellow-400 text-slate-950 px-8 py-4 rounded-full font-black text-xs shadow-[0_20px_50px_rgba(250,204,21,0.4)] z-[200] uppercase italic flex items-center gap-3 animate-in slide-in-from-bottom-10 border-2 border-white">
          <CheckCircle size={18} /> {notification}
        </div>
      )}

    </div>
  );
};

export default App;
