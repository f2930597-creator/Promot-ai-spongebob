import React, { useState, useEffect, useMemo } from 'react';
import { initializeApp, getApps } from 'firebase/app';
import { 
  getFirestore, 
  collection, 
  addDoc, 
  onSnapshot 
} from 'firebase/firestore';
import { 
  getAuth, 
  signInAnonymously, 
  signInWithCustomToken, 
  onAuthStateChanged 
} from 'firebase/auth';
import { 
  Copy, 
  Sparkles, 
  CheckCircle,
  MapPin,
  Users,
  Loader2,
  X,
  Mic2,
  BookOpen,
  Palette,
  Zap,
  Monitor,
  Camera
} from 'lucide-react';

// Firebase Config Logic
let auth = null;
let db = null;
const appId = typeof __app_id !== 'undefined' ? __app_id : 'bikini-script-studio-v3';

const App = () => {
  const [authStatus, setAuthStatus] = useState('menghubungkan');
  const [user, setUser] = useState(null);
  
  const [inputStory, setInputStory] = useState('');
  const [inputDialogue, setInputDialogue] = useState('');
  const [selectedLocation, setSelectedLocation] = useState('Pusat Kota');
  const [selectedCitizen, setSelectedCitizen] = useState('Scooter');
  
  const [generatedScript, setGeneratedScript] = useState('');
  const [isProcessing, setIsProcessing] = useState(false);
  const [notification, setNotification] = useState(null);
  const [publicScripts, setPublicScripts] = useState([]);

  const locationDetails = {
    'Krusty Krab': 'Krusty Krab exterior with wooden barrel tables and nautical anchor architecture',
    'Rumah Nanas': 'Pineapple house with bamboo mailbox and stylized sand mounds',
    'Goo Lagoon': 'lifeguard towers and purple brine pools under striped umbrellas',
    'Pusat Kota': 'street lights shaped like fishing rods, blue-stone pavement, and coral buildings',
    'Ladang Ubur-ubur': 'pink coral trees and floating kelp formations with bubble holes'
  };

  const iconicCitizens = useMemo(() => [
    { id: 'Scooter', name: 'Scooter', icon: '🏄', desc: 'Purple surfer fish' },
    { id: 'Fred', name: 'Fred', icon: '🦵', desc: 'Brown fish, olive green pants' },
    { id: 'Tom', name: 'Tom', icon: '🍫', desc: 'Green fish, purple shirt' },
    { id: 'Nat', name: 'Nat', icon: '🐟', desc: 'Yellow fish, blue shorts' },
    { id: 'Harold', name: 'Harold', icon: '👕', desc: 'Light blue fish, white shirt' },
    { id: 'Old Man Jenkins', name: 'Old Man Jenkins', icon: '👴', desc: 'Dark grey elderly fish' }
  ], []);

  const locations = useMemo(() => [
    { name: 'Pusat Kota', icon: '🏢' },
    { name: 'Krusty Krab', icon: '🍔' },
    { name: 'Rumah Nanas', icon: '🏠' },
    { name: 'Goo Lagoon', icon: '🏖️' },
    { name: 'Ladang Ubur-ubur', icon: '🧤' }
  ], []);

  useEffect(() => {
    const startFirebase = async () => {
      try {
        const firebaseConfigRaw = typeof __firebase_config !== 'undefined' ? __firebase_config : null;
        if (firebaseConfigRaw && getApps().length === 0) {
          const config = JSON.parse(firebaseConfigRaw);
          const app = initializeApp(config);
          auth = getAuth(app);
          db = getFirestore(app);
          
          if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
            await signInWithCustomToken(auth, __initial_auth_token);
          } else {
            await signInAnonymously(auth);
          }
        }
      } catch (e) {
        setAuthStatus('offline');
      }
    };
    startFirebase();

    if (auth) {
      const unsubscribe = onAuthStateChanged(auth, (u) => {
        if (u) {
          setUser(u);
          setAuthStatus('online');
        }
      });
      return () => unsubscribe();
    }
  }, []);

  useEffect(() => {
    if (!db || !user) return;
    try {
      const col = collection(db, 'artifacts', appId, 'public', 'data', 'scripts');
      const unsubscribe = onSnapshot(col, (snapshot) => {
        const data = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
        setPublicScripts(data.sort((a, b) => (b.timestamp || 0) - (a.timestamp || 0)).slice(0, 12));
      }, (err) => console.error(err));
      return () => unsubscribe();
    } catch (e) {}
  }, [user]);

  const showNotification = (msg) => {
    setNotification(msg);
    setTimeout(() => setNotification(null), 3000);
  };

  const copyToClipboard = (text) => {
    const target = text || generatedScript;
    if (!target) return;
    const textArea = document.createElement("textarea");
    textArea.value = target;
    document.body.appendChild(textArea);
    textArea.select();
    try {
      document.execCommand('copy');
      showNotification("Prompt berhasil disalin!");
    } catch (err) {
      showNotification("Gagal menyalin.");
    }
    document.body.removeChild(textArea);
  };

  const handleGenerate = async () => {
    setIsProcessing(true);
    const citizen = iconicCitizens.find(c => c.id === selectedCitizen);
    const locDetail = locationDetails[selectedLocation];
    
    // Constructing the detailed prompt based on requirements
    const scriptBody = `SCENE:
A 15-second 2D underwater animated scene inspired by Bikini Bottom. The camera is a static medium shot (no movement), showing a bright and colorful underwater environment.

VISUAL STYLE:
Classic 90s TV cartoon aesthetic with thick black outlines, bright colors, cel-shading, and high saturation. Use “squash and stretch” animation principles for object movement.

BACKGROUND PROPS:
${locDetail}. All objects use hand-painted watercolor-style textures. Lighting is cinematic with high detail and 4K quality.

NOTES:
No human characters appear in the scene. Main character is ${citizen.name} (${citizen.desc}).

CHARACTER SETUP:
- MAIN CHARACTER: ${citizen.name}, fully visible, neutral pose.
- BACKGROUND EXTRAS: Additional Bikini Bottom fish citizens appear briefly in the background (purely decorative).

GEMINI AI CUSTOMIZATION:
- DIALOG: "${inputDialogue}"
- STORY / PLOT: ${inputStory}

AUDIO & DUBBING:
- VOICE: Exaggerated cartoon dubbing with a high-pitched tone, slightly nasal or raspy depending on expression.
- BACKGROUND SOUND: Nautical slapstick music using ukulele and accordion. Add classic sound effects like “slide whistles,” “boing,” and bubble pops.`;

    setGeneratedScript(scriptBody);
    
    if (db && user) {
      try {
        await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'scripts'), {
          citizen: citizen.name,
          location: selectedLocation,
          script: scriptBody,
          timestamp: Date.now(),
          userName: `Director-${user.uid.slice(0, 4)}`
        });
      } catch (e) {}
    }
    
    setIsProcessing(false);
  };

  return (
    <div className="h-screen w-screen bg-[#050505] text-slate-200 font-sans flex flex-col overflow-hidden relative">
      <header className="h-14 border-b border-white/10 bg-black/50 backdrop-blur-md flex items-center justify-between px-6 shrink-0 z-50">
        <div className="flex items-center gap-3">
          <div className="w-8 h-8 bg-cyan-600 rounded-lg flex items-center justify-center rotate-3 shadow-lg shadow-cyan-500/40">
            <Monitor size={18} className="text-white" />
          </div>
          <h1 className="text-xs font-black tracking-tighter uppercase italic text-white">
            BIKINI BOTTOM <span className="text-cyan-400 font-bold tracking-widest">PROMPT ENGINE</span>
          </h1>
        </div>
        <div className="text-[9px] font-bold text-slate-500 uppercase tracking-widest">
           {authStatus === 'online' ? 'Global Cloud Active' : 'Offline Mode'}
        </div>
      </header>

      <main className="flex flex-1 overflow-hidden flex-col lg:flex-row">
        <aside className="w-full lg:w-[400px] border-r border-white/5 bg-[#0a0a0a] flex flex-col overflow-y-auto p-6 space-y-8 scrollbar-hide">
          <section className="space-y-4">
            <label className="text-[10px] font-black text-slate-500 uppercase tracking-widest flex items-center gap-2">
              <Users size={14} className="text-cyan-500" /> Pilih Karakter
            </label>
            <div className="grid grid-cols-3 gap-2">
              {iconicCitizens.map(c => (
                <button 
                  key={c.id} 
                  onClick={() => setSelectedCitizen(c.id)}
                  className={`flex flex-col items-center p-3 rounded-2xl border-2 transition-all ${selectedCitizen === c.id ? 'bg-cyan-600/10 border-cyan-500 scale-105 shadow-xl shadow-cyan-500/10' : 'bg-white/5 border-white/5 opacity-40 hover:opacity-100'}`}
                >
                  <span className="text-2xl mb-1">{c.icon}</span>
                  <span className="text-[8px] font-black uppercase text-center">{c.name}</span>
                </button>
              ))}
            </div>
          </section>

          <section className="space-y-4">
            <label className="text-[10px] font-black text-slate-500 uppercase tracking-widest flex items-center gap-2">
              <MapPin size={14} className="text-cyan-500" /> Lokasi Adegan
            </label>
            <div className="grid grid-cols-2 gap-2">
              {locations.map(loc => (
                <button 
                  key={loc.name} 
                  onClick={() => setSelectedLocation(loc.name)}
                  className={`px-4 py-3 rounded-xl text-[9px] font-black uppercase transition-all border-2 flex items-center gap-2 ${selectedLocation === loc.name ? 'bg-cyan-600 border-cyan-400 text-white shadow-lg shadow-cyan-500/10' : 'bg-white/5 border-white/5 opacity-40 hover:opacity-100'}`}
                >
                  <span>{loc.icon}</span> {loc.name}
                </button>
              ))}
            </div>
          </section>

          <section className="space-y-4">
            <label className="text-[10px] font-black text-slate-500 uppercase tracking-widest flex items-center gap-2">
              <BookOpen size={14} className="text-cyan-500" /> Input Kustom
            </label>
            <div className="space-y-3">
              <textarea 
                placeholder="Tulis STORY / PLOT di sini..."
                value={inputStory}
                onChange={(e) => setInputStory(e.target.value)}
                className="w-full bg-[#111] border border-white/10 rounded-xl p-4 text-xs h-32 focus:border-cyan-500 outline-none transition-all resize-none text-cyan-50 placeholder:text-slate-700"
              />
              <div className="relative">
                <Mic2 size={14} className="absolute left-4 top-1/2 -translate-y-1/2 text-cyan-500" />
                <input 
                  placeholder="Tulis DIALOG di sini..."
                  value={inputDialogue}
                  onChange={(e) => setInputDialogue(e.target.value)}
                  className="w-full bg-[#111] border border-white/10 rounded-xl pl-10 pr-4 py-3 text-xs focus:border-cyan-500 outline-none transition-all text-cyan-50 placeholder:text-slate-700"
                />
              </div>
            </div>
          </section>

          <button 
            onClick={handleGenerate}
            disabled={isProcessing}
            className={`w-full py-5 rounded-2xl font-black uppercase italic transition-all flex items-center justify-center gap-3 text-xs tracking-widest ${isProcessing ? 'bg-slate-800 opacity-50' : 'bg-cyan-600 text-white hover:bg-cyan-500 shadow-lg shadow-cyan-900/20'}`}
          >
            {isProcessing ? <Loader2 className="animate-spin" size={16} /> : <><Sparkles size={16} /> GENERATE PROMPT</>}
          </button>
        </aside>

        <section className="flex-1 bg-[#050505] flex flex-col relative overflow-hidden">
          <div className="h-12 px-8 border-b border-white/5 flex items-center justify-between bg-black/40 backdrop-blur-sm z-10">
            <div className="flex items-center gap-2">
              <Camera size={14} className="text-cyan-400" />
              <h2 className="text-[9px] font-black uppercase tracking-widest text-slate-500 italic">Cinematic 4K Rendering Feed</h2>
            </div>
          </div>

          <div className="flex-1 overflow-y-auto p-8 scrollbar-hide pb-20">
            <div className="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-5xl mx-auto">
              {publicScripts.map((s) => (
                <div key={s.id} className="bg-white/[0.02] border border-white/5 rounded-2xl p-5 flex flex-col gap-3 group hover:border-cyan-500/30 transition-all shadow-xl">
                  <div className="flex justify-between items-start">
                    <span className="text-[10px] font-black text-cyan-400 uppercase italic tracking-widest">{s.citizen} @ {s.location}</span>
                    <button onClick={() => copyToClipboard(s.script)} className="p-2.5 rounded-xl bg-white/5 text-slate-500 hover:text-white hover:bg-cyan-600 transition-all">
                      <Copy size={12} />
                    </button>
                  </div>
                  <pre className="text-[9px] text-slate-600 italic leading-relaxed whitespace-pre-wrap font-mono line-clamp-4">
                    {s.script}
                  </pre>
                </div>
              ))}
            </div>
          </div>

          {generatedScript && (
            <div className="absolute inset-0 z-[100] flex items-center justify-center p-6 bg-black/95 backdrop-blur-xl">
              <div className="bg-[#0f0f0f] text-white p-10 rounded-[2.5rem] shadow-2xl border border-white/10 w-full max-w-2xl relative animate-in zoom-in-95 duration-300">
                <button onClick={() => setGeneratedScript('')} className="absolute top-8 right-8 p-2 text-slate-500 hover:text-white"><X size={24} /></button>
                
                <div className="flex items-center gap-4 mb-8">
                  <Zap size={24} className="text-cyan-400 fill-cyan-400" />
                  <div>
                    <h3 className="text-sm font-black uppercase tracking-widest text-white italic">4K CINEMATIC PROMPT</h3>
                    <p className="text-[9px] text-cyan-600 font-bold uppercase tracking-widest">Bikini Bottom Aesthetic Ready</p>
                  </div>
                </div>

                <div className="bg-black/60 p-6 rounded-2xl mb-8 border border-white/5 max-h-[300px] overflow-y-auto custom-scrollbar shadow-inner">
                  <pre className="text-[10px] font-mono leading-relaxed text-cyan-50/70 whitespace-pre-wrap">
                    {generatedScript}
                  </pre>
                </div>

                <button onClick={() => copyToClipboard()} className="w-full py-5 bg-cyan-600 hover:bg-cyan-500 text-white rounded-2xl font-black text-[10px] uppercase shadow-2xl transition-all flex items-center justify-center gap-3 tracking-[0.2em] italic">
                  <Copy size={18} /> SALIN PROMPT SEKARANG
                </button>
              </div>
            </div>
          )}
        </section>
      </main>

      {notification && (
        <div className="fixed bottom-8 left-1/2 -translate-x-1/2 bg-cyan-600 text-white px-8 py-4 rounded-full font-black text-[10px] shadow-2xl z-[300] uppercase italic flex items-center gap-3 animate-in slide-in-from-bottom-5">
          <CheckCircle size={16} /> {notification}
        </div>
      )}

      <style>{`
        .scrollbar-hide::-webkit-scrollbar { display: none; }
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #083344; border-radius: 10px; }
      `}</style>
    </div>
  );
};

export default App;
